//@version=6
strategy("V71 Pesquisa TV 3H DMI3 Robusto FIXO",
     overlay=true,
     pyramiding=0,
     default_qty_type=strategy.fixed,
     default_qty_value=1)

// Pesquisa separada. Nao altera o V7.1 oficial.
// Candidato gerado por simulacao em candles IBKR 2min.
// Regras-base 3H + filtro de regime: gap DMI >= 3.
takePontos = input.float(50.5, "Take em pontos", step=0.25)
stopPontos = input.float(117.0, "Stop em pontos", step=0.25)
dmiGapMin = input.float(3.0, "Gap minimo DMI", step=0.5)
mostrarPainel = input.bool(true, "Mostrar painel de auditoria")

takeTicks = int(math.round(takePontos / syminfo.mintick))
stopTicks = int(math.round(stopPontos / syminfo.mintick))

hSP = hour(time, "America/Sao_Paulo")
mSP = minute(time, "America/Sao_Paulo")
dowSP = dayofweek(time, "America/Sao_Paulo")

eh0348 = hSP == 3 and mSP == 48
eh1030 = hSP == 10 and mSP == 30
eh2058 = hSP == 20 and mSP == 58

ema17 = ta.ema(close, 17)
ema34 = ta.ema(close, 34)
sma17 = ta.sma(close, 17)
sma34 = ta.sma(close, 34)
ema12 = ta.ema(close, 12)
ema26 = ta.ema(close, 26)
macd = ema12 - ema26
macdSignal = ta.ema(macd, 9)
roc5 = close - close[5]
roc10 = close - close[10]
prevRoc5 = roc5[1]
body = close - open
vwapDia = ta.vwap(hlc3)
[diPlus, diMinus, adx14] = ta.dmi(14, 14)
dmiGap = math.abs(diPlus - diMinus)
regimeOk = dmiGap >= dmiGapMin

plot(ema17, "EMA 17", color=color.purple, linewidth=2)
plot(ema34, "EMA 34", color=color.blue, linewidth=2)

votoMacd = macd >= macdSignal ? 1 : -1
votoCandle = body >= 0 ? 1 : -1
votoPrevRoc5Contra = prevRoc5 <= 0 ? 1 : -1
votoSma1734 = sma17 >= sma34 ? 1 : -1
votoRoc10 = roc10 >= 0 ? 1 : -1
votoEma1734 = ema17 >= ema34 ? 1 : -1
votoRoc5 = roc5 >= 0 ? 1 : -1
votoVwap = close >= vwapDia ? 1 : -1

score0348 = votoMacd + votoCandle + votoPrevRoc5Contra
score1030 = votoSma1734 + votoRoc10 + votoPrevRoc5Contra
score2058 = votoEma1734 + votoRoc5 + votoVwap

buy0348 = regimeOk and eh0348 and score0348 >= 0 and (dowSP == dayofweek.monday or dowSP == dayofweek.tuesday)
buy1030 = regimeOk and eh1030 and score1030 >= 0 and dowSP == dayofweek.monday
sell1030 = regimeOk and eh1030 and score1030 < 0 and dowSP == dayofweek.friday
buy2058 = regimeOk and eh2058 and score2058 >= 0 and (dowSP == dayofweek.sunday or dowSP == dayofweek.wednesday)

compraCond = buy0348 or buy1030 or buy2058
vendaCond = sell1030

if buy0348
    strategy.entry("BUY_0348", strategy.long, alert_message="V71 PESQUISA 3H DMI3 BUY 03:48")

if buy1030
    strategy.entry("BUY_1030", strategy.long, alert_message="V71 PESQUISA 3H DMI3 BUY 10:30")

if buy2058
    strategy.entry("BUY_2058", strategy.long, alert_message="V71 PESQUISA 3H DMI3 BUY 20:58")

if sell1030
    strategy.entry("SELL_1030", strategy.short, alert_message="V71 PESQUISA 3H DMI3 SELL 10:30")

strategy.exit("TP/SL BUY_0348", from_entry="BUY_0348", profit=takeTicks, loss=stopTicks)
strategy.exit("TP/SL BUY_1030", from_entry="BUY_1030", profit=takeTicks, loss=stopTicks)
strategy.exit("TP/SL BUY_2058", from_entry="BUY_2058", profit=takeTicks, loss=stopTicks)
strategy.exit("TP/SL SELL_1030", from_entry="SELL_1030", profit=takeTicks, loss=stopTicks)

plotshape(buy0348, title="BUY 03:48", style=shape.triangleup, location=location.belowbar,
     color=color.lime, size=size.normal, text="B0348")
plotshape(buy1030, title="BUY 10:30", style=shape.triangleup, location=location.belowbar,
     color=color.green, size=size.normal, text="B1030")
plotshape(buy2058, title="BUY 20:58", style=shape.triangleup, location=location.belowbar,
     color=color.teal, size=size.normal, text="B2058")
plotshape(sell1030, title="SELL 10:30", style=shape.triangledown, location=location.abovebar,
     color=color.red, size=size.normal, text="S1030")

alertcondition(compraCond, title="V71 Pesquisa 3H DMI3 BUY", message="V71 PESQUISA 3H DMI3 BUY")
alertcondition(vendaCond, title="V71 Pesquisa 3H DMI3 SELL", message="V71 PESQUISA 3H DMI3 SELL")

var table painel = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 20))
if mostrarPainel and barstate.islast
    table.cell(painel, 0, 0, "V71 3H", text_color=color.white)
    table.cell(painel, 1, 0, "DMI3 PESQUISA", text_color=color.yellow)
    table.cell(painel, 0, 1, "03:48", text_color=color.white)
    table.cell(painel, 1, 1, "BUY seg/ter", text_color=color.lime)
    table.cell(painel, 0, 2, "10:30", text_color=color.white)
    table.cell(painel, 1, 2, "BUY seg / SELL sex", text_color=color.lime)
    table.cell(painel, 0, 3, "20:58", text_color=color.white)
    table.cell(painel, 1, 3, "BUY dom/qua", text_color=color.lime)
    table.cell(painel, 0, 4, "Filtro", text_color=color.white)
    table.cell(painel, 1, 4, "DMI gap >= " + str.tostring(dmiGapMin), text_color=color.white)
    table.cell(painel, 0, 5, "TP/SL", text_color=color.white)
    table.cell(painel, 1, 5, str.tostring(takePontos) + " / " + str.tostring(stopPontos), text_color=color.white)
    table.cell(painel, 0, 6, "Oficial", text_color=color.white)
    table.cell(painel, 1, 6, "NAO ALTERADO", text_color=color.orange)
