//@version=6
strategy("V71 Pesquisa TV Alta Acertividade Calendario",
     overlay=true,
     pyramiding=0,
     default_qty_type=strategy.fixed,
     default_qty_value=1)

// Pesquisa baseada no export TradingView.
// Foca em acerto maior filtrando dias/horarios. Nao altera o V7.1 oficial.
takePontos = input.float(50.5, "Take em pontos", step=0.25)
stopPontos = input.float(110.0, "Stop em pontos", step=0.25)
modo = input.string("81pct_105trades", "Modo",
     options=["87pct_54trades", "84pct_78trades", "81pct_105trades", "79pct_129trades"])

takeTicks = int(math.round(takePontos / syminfo.mintick))
stopTicks = int(math.round(stopPontos / syminfo.mintick))

hSP = hour(time, "America/Sao_Paulo")
mSP = minute(time, "America/Sao_Paulo")
dowSP = dayofweek(time, "America/Sao_Paulo")

ema17 = ta.ema(close, 17)
ema34 = ta.ema(close, 34)
ema12 = ta.ema(close, 12)
ema26 = ta.ema(close, 26)
macd = ema12 - ema26
macdSignal = ta.ema(macd, 9)
roc5 = close - close[5]
prevRoc5 = roc5[1]
body = close - open
vwapDia = ta.vwap(hlc3)

plot(ema17, "EMA 17", color=color.purple, linewidth=2)
plot(ema34, "EMA 34", color=color.blue, linewidth=2)

votoMacd = macd >= macdSignal ? 1 : -1
votoCandle = body >= 0 ? 1 : -1
votoPrevRoc5Contra = prevRoc5 <= 0 ? 1 : -1
votoEma1734 = ema17 >= ema34 ? 1 : -1
votoRoc5 = roc5 >= 0 ? 1 : -1
votoVwap = close >= vwapDia ? 1 : -1

score0348 = votoMacd + votoCandle + votoPrevRoc5Contra
score2058 = votoEma1734 + votoRoc5 + votoVwap

eh0348 = hSP == 3 and mSP == 48
eh2058 = hSP == 20 and mSP == 58

usar0348Seg = eh0348 and dowSP == dayofweek.monday
usar0348Ter = eh0348 and dowSP == dayofweek.tuesday
usar2058Dom = eh2058 and dowSP == dayofweek.sunday
usar2058Ter = eh2058 and dowSP == dayofweek.tuesday
usar2058Qua = eh2058 and dowSP == dayofweek.wednesday

bool cal0348 = false
bool cal2058 = false

if modo == "87pct_54trades"
    cal0348 := usar0348Seg
    cal2058 := usar2058Dom
else if modo == "84pct_78trades"
    cal0348 := usar0348Seg
    cal2058 := usar2058Dom or usar2058Ter
else if modo == "81pct_105trades"
    cal0348 := usar0348Seg or usar0348Ter
    cal2058 := usar2058Dom or usar2058Ter
else
    cal0348 := usar0348Seg or usar0348Ter
    cal2058 := usar2058Dom or usar2058Ter or usar2058Qua

buy0348 = cal0348 and score0348 >= 0
buy2058 = cal2058 and score2058 >= 0
compraCond = buy0348 or buy2058

if buy0348
    strategy.entry("BUY_0348_CAL", strategy.long, alert_message="V71 TV CAL BUY 03:48")

if buy2058
    strategy.entry("BUY_2058_CAL", strategy.long, alert_message="V71 TV CAL BUY 20:58")

strategy.exit("TP/SL BUY_0348", from_entry="BUY_0348_CAL", profit=takeTicks, loss=stopTicks)
strategy.exit("TP/SL BUY_2058", from_entry="BUY_2058_CAL", profit=takeTicks, loss=stopTicks)

plotshape(buy0348, title="BUY 03:48 CAL", style=shape.triangleup, location=location.belowbar,
     color=color.lime, size=size.normal, text="B0348")
plotshape(buy2058, title="BUY 20:58 CAL", style=shape.triangleup, location=location.belowbar,
     color=color.green, size=size.normal, text="B2058")

alertcondition(compraCond, title="V71 TV CAL BUY", message="V71 TV CAL BUY")
