//@version=5
strategy("V7.1 PESQUISA - 04:06 Reversao 6min", shorttitle="V71 0406 Pesquisa", overlay=true,
     default_qty_type=strategy.fixed, default_qty_value=1,
     initial_capital=50000, currency=currency.USD,
     commission_type=strategy.commission.cash_per_contract, commission_value=0.85,
     process_orders_on_close=true)

// ============================================================
// PESQUISA ISOLADA - NAO E O ROBO OFICIAL
// Use no grafico de 6 minutos.
// Candidato robusto da rotacao:
// 04:06 SP, reversao, take 50.5, stop 117, range_ratio_10 <= 1.5.
// ============================================================

// === CONFIG ===
modo_pesquisa = input.string("ROBUSTO_81", "Modo", options=["ROBUSTO_81", "EXPLORATORIO_85"], group="Pesquisa")
take_pts      = input.float(50.5, "Take Profit pts", group="Risco")
stop_pts      = input.float(117.0, "Stop Loss pts", group="Risco")
h_entrada     = input.int(4, "Hora entrada SP", group="Horario", minval=0, maxval=23)
m_entrada     = input.int(6, "Min entrada SP", group="Horario", minval=0, maxval=59)
range_max     = input.float(1.5, "Max range_ratio_10", group="Filtros", step=0.1)
extremo_min   = input.float(0.80, "Extremo min modo 85", group="Filtros", step=0.05)
show_marks    = input.bool(true, "Mostrar sinais", group="Visual")
show_table    = input.bool(true, "Mostrar tabela", group="Visual")
show_bg       = input.bool(true, "Destacar candle 04:06", group="Visual")

// === HORARIO SP ===
h_sp = hour(time, "America/Sao_Paulo")
m_sp = minute(time, "America/Sao_Paulo")
na_entrada = h_sp == h_entrada and m_sp == m_entrada

// === CONTROLE 1 TRADE POR DIA ===
var int dia_controle = 0
var bool entrou_hoje = false

dia_atual = year * 10000 + month * 100 + dayofmonth
if dia_atual != dia_controle
    entrou_hoje := false
    dia_controle := dia_atual

// === CANDLE 6MIN / REVERSAO ===
range_atual = high - low
range_med_10 = ta.sma(range_atual, 10)
range_ratio_10 = range_atual / math.max(range_med_10, syminfo.mintick)

max_20 = ta.highest(high, 20)
min_20 = ta.lowest(low, 20)
pos_range_20 = (close - min_20) / math.max(max_20 - min_20, syminfo.mintick)

// Mesma regra usada no Python:
// BUY quando o fechamento esta perto do fundo dos ultimos 20 candles.
// SELL quando o fechamento esta perto do topo dos ultimos 20 candles.
dir_buy = pos_range_20 <= 0.35
dir_sell = pos_range_20 >= 0.65

extremo_reversao = dir_buy ? 1.0 - pos_range_20 : dir_sell ? pos_range_20 : na
direcao_candle_buy = close >= open
mesmo_sentido_candle = dir_buy ? direcao_candle_buy : dir_sell ? not direcao_candle_buy : false

filtro_robusto = range_ratio_10 <= range_max
filtro_85 = filtro_robusto and extremo_reversao >= extremo_min and not mesmo_sentido_candle
filtro_final = modo_pesquisa == "ROBUSTO_81" ? filtro_robusto : filtro_85

tem_reversao = dir_buy or dir_sell
pode_entrar = na_entrada and not entrou_hoje and tem_reversao and filtro_final and strategy.position_size == 0

compra = pode_entrar and dir_buy
venda = pode_entrar and dir_sell

// === EXECUCAO ===
tk = syminfo.mintick
if compra
    strategy.entry("BUY_0406", strategy.long)
    strategy.exit("BUY_0406_X", "BUY_0406", profit=math.round(take_pts / tk), loss=math.round(stop_pts / tk))
    entrou_hoje := true

if venda
    strategy.entry("SELL_0406", strategy.short)
    strategy.exit("SELL_0406_X", "SELL_0406", profit=math.round(take_pts / tk), loss=math.round(stop_pts / tk))
    entrou_hoje := true

// === ALERTAS ===
alertcondition(compra, "V71 Pesquisa BUY", "V71 Pesquisa BUY")
alertcondition(venda, "V71 Pesquisa SELL", "V71 Pesquisa SELL")

// === VISUAL ===
bgcolor(show_bg and na_entrada ? color.new(color.yellow, 82) : na, title="Candle entrada 04:06")

plotshape(show_marks and compra, style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.large, text="BUY 0406")
plotshape(show_marks and venda, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.large, text="SELL 0406")

plot(pos_range_20, "pos_range_20", color=color.new(color.aqua, 0), display=display.data_window)
plot(range_ratio_10, "range_ratio_10", color=color.new(color.orange, 0), display=display.data_window)
plot(extremo_reversao, "extremo_reversao", color=color.new(color.fuchsia, 0), display=display.data_window)

// === TABELA ===
var table t = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 75), border_color=color.gray, border_width=1)
if show_table and barstate.islast
    h_txt = h_entrada < 10 ? "0" + str.tostring(h_entrada) : str.tostring(h_entrada)
    m_txt = m_entrada < 10 ? "0" + str.tostring(m_entrada) : str.tostring(m_entrada)
    table.cell(t, 0, 0, "Modo", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, modo_pesquisa, text_color=modo_pesquisa == "ROBUSTO_81" ? color.lime : color.orange, text_size=size.small)
    table.cell(t, 0, 1, "Horario", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, h_txt + ":" + m_txt, text_color=color.white, text_size=size.small)
    table.cell(t, 0, 2, "Direcao", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, dir_buy ? "BUY" : dir_sell ? "SELL" : "NONE", text_color=dir_buy ? color.lime : dir_sell ? color.red : color.gray, text_size=size.small)
    table.cell(t, 0, 3, "RangeRatio10", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(range_ratio_10, "#.##"), text_color=filtro_robusto ? color.lime : color.red, text_size=size.small)
    table.cell(t, 0, 4, "PosRange20", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(pos_range_20, "#.##"), text_color=tem_reversao ? color.lime : color.gray, text_size=size.small)
    table.cell(t, 0, 5, "Extremo", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, str.tostring(extremo_reversao, "#.##"), text_color=extremo_reversao >= extremo_min ? color.lime : color.gray, text_size=size.small)
    table.cell(t, 0, 6, "Candle contra", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 6, not mesmo_sentido_candle ? "SIM" : "NAO", text_color=not mesmo_sentido_candle ? color.lime : color.gray, text_size=size.small)
    table.cell(t, 0, 7, "Entrou hoje", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 7, entrou_hoje ? "SIM" : "NAO", text_color=entrou_hoje ? color.orange : color.lime, text_size=size.small)
